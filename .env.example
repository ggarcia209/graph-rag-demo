# FalkorDB connection settings
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=

# Open LLM API settings (e.g., vLLM, Ollama, or custom endpoint)
# We use open models like Qwen-3 embedding and Qwen-2.5 VL
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding
